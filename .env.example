# ============================================================
# Da Xing Xing — Environment Variables
# Copy to `.env.local` and fill in. The app runs fully on mock
# data with NONE of these set — configure them to enable the
# real backend, payments, and AI.
# ============================================================

# ---- App ----
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---- Supabase (database, auth, storage, realtime) ----
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. NEVER expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# ---- Stripe (subscriptions, packages, deposits, production payments) ----
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Stripe Price IDs (created in the Stripe dashboard). Admin-editable in prod.
STRIPE_PRICE_BUILDER=
STRIPE_PRICE_COMPANY=
STRIPE_PRICE_PROTOTYPE=

# ---- AI provider (product design conversations) ----
# Set ONE provider. Falls back to the built-in mock if unset.
AI_PROVIDER=mock            # mock | anthropic | openai
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
